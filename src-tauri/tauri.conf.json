{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "devPath": "../frontend/dist",
    "distDir": "../frontend/dist"
  },
  "package": {
    "productName": "AI Term",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.tf1997.ai-term",
      "publisher": "tf1997",
      "category": "DeveloperTool",
      "shortDescription": "AI assisted terminal and script workspace.",
      "longDescription": "AI Term is a desktop terminal workspace with AI assisted command and script workflows.",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon-256.png",
        "icons/icon-512.png",
        "icons/icon.png",
        "icons/icon.ico",
        "icons/icon.icns"
      ],
      "windows": {
        "webviewInstallMode": {
          "type": "downloadBootstrapper",
          "silent": true
        }
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "AI Term",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640
      }
    ]
  }
}
