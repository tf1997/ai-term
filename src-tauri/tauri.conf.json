{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "devPath": "../frontend/dist",
    "distDir": "../frontend/dist"
  },
  "package": {
    "productName": "AI Term",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": false,
      "identifier": "com.tf1997.ai-term",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon-256.png",
        "icons/icon-512.png",
        "icons/icon.png"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "AI Term",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640
      }
    ]
  }
}
